<?xml version="1.0" encoding="utf-8"?>
<!--
  M3 Expressive island cluster: a header row, then one island per concern —
  the chart tile (rainy) or an accent NOW cell + neutral stats cell (dry),
  and a full-width headline chip shared by both states so the nowcast
  message always has the same uncropped home. Islands use 16dp radii
  (outer 28dp minus the 12dp card padding) with 8dp gutters.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="2dp">

        <ImageView
            android:id="@+id/condition"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="6dp"
            android:src="@drawable/ic_cond_clear"
            android:contentDescription="@string/widget_label" />

        <TextView
            android:id="@+id/location"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/widget_text"
            android:textSize="12sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end"
            android:text="@string/loading" />

        <TextView
            android:id="@+id/updated"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:textColor="@color/widget_subtle"
            android:textSize="12sp"
            android:singleLine="true"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:background="@drawable/updated_pill_background"
            android:text="" />
    </LinearLayout>

    <!-- Rainy island: the dual-provider chart bitmap on its own tonal tile. -->
    <ImageView
        android:id="@+id/chart"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:scaleType="fitXY"
        android:adjustViewBounds="false"
        android:background="@drawable/island_neutral"
        android:contentDescription="@string/widget_label" />

    <!-- Rainy stats row: native temps + micro stats under the chart island,
         anchored to the corners like the time labels above them (the time
         row inside the bitmap is what labels each cluster as now / end).
         Native because bitmap text goes soft under fitXY. -->
    <LinearLayout
        android:id="@+id/rain_stats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/rain_temp_now"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="7dp"
            android:textColor="@color/widget_text"
            android:textSize="17sp"
            android:textFontWeight="700"
            android:text="" />

        <TextView
            android:id="@+id/rain_micro_now"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/widget_subtle"
            android:textSize="12.5sp"
            android:singleLine="true"
            android:text="" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="" />

        <TextView
            android:id="@+id/rain_micro_end"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="7dp"
            android:textColor="@color/widget_subtle"
            android:textSize="12.5sp"
            android:singleLine="true"
            android:text="" />

        <TextView
            android:id="@+id/rain_temp_end"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/chart_temp"
            android:textSize="17sp"
            android:textFontWeight="700"
            android:text="" />
    </LinearLayout>

    <!-- Dry islands: accent NOW cell + neutral stats cell. -->
    <LinearLayout
        android:id="@+id/dry_body"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/island_accent"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/widget_subtle"
                android:textSize="10sp"
                android:textFontWeight="700"
                android:letterSpacing="0.16"
                android:text="@string/now_label" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="2dp">

                <ImageView
                    android:id="@+id/dry_condition"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="8dp"
                    android:src="@drawable/ic_cond_clear"
                    android:contentDescription="@string/widget_label" />

                <TextView
                    android:id="@+id/dry_temp_now"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/widget_text"
                    android:textSize="54sp"
                    android:textFontWeight="300"
                    android:includeFontPadding="false"
                    android:text="" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/widget_subtle"
                    android:textSize="10sp"
                    android:textFontWeight="700"
                    android:letterSpacing="0.16"
                    android:layout_marginEnd="6dp"
                    android:text="@string/plus2h_label" />

                <TextView
                    android:id="@+id/dry_temp_end"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/chart_temp"
                    android:textSize="17sp"
                    android:textFontWeight="600"
                    android:text="" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/dry_sunset_row"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="5dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/widget_subtle"
                    android:textSize="10sp"
                    android:textFontWeight="700"
                    android:letterSpacing="0.16"
                    android:layout_marginEnd="6dp"
                    android:text="@string/sunset_label" />

                <TextView
                    android:id="@+id/dry_sunset_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/widget_text"
                    android:textSize="13sp"
                    android:textFontWeight="600"
                    android:text="" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:background="@drawable/island_neutral"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="5dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="" />

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:textColor="@color/widget_subtle"
                    android:textSize="9sp"
                    android:textFontWeight="700"
                    android:letterSpacing="0.1"
                    android:text="@string/now_label" />

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:textColor="@color/widget_subtle"
                    android:textSize="9sp"
                    android:textFontWeight="700"
                    android:letterSpacing="0.1"
                    android:text="@string/plus2h_label" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/widget_subtle"
                    android:textSize="12sp"
                    android:textFontWeight="600"
                    android:text="@string/stat_feels" />

                <TextView
                    android:id="@+id/dry_feels_now"
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:textColor="@color/widget_text"
                    android:textSize="14sp"
                    android:textFontWeight="600"
                    android:text="" />

                <TextView
                    android:id="@+id/dry_feels_end"
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:textColor="@color/widget_subtle"
                    android:textSize="14sp"
                    android:textFontWeight="600"
                    android:text="" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/widget_subtle"
                    android:textSize="12sp"
                    android:textFontWeight="600"
                    android:text="@string/stat_wind" />

                <TextView
                    android:id="@+id/dry_wind_now"
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:textColor="@color/widget_text"
                    android:textSize="14sp"
                    android:textFontWeight="600"
                    android:text="" />

                <TextView
                    android:id="@+id/dry_wind_end"
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:textColor="@color/widget_subtle"
                    android:textSize="14sp"
                    android:textFontWeight="600"
                    android:text="" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/widget_subtle"
                    android:textSize="12sp"
                    android:textFontWeight="600"
                    android:text="@string/stat_uv" />

                <TextView
                    android:id="@+id/dry_uv_now"
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:textColor="@color/widget_text"
                    android:textSize="14sp"
                    android:textFontWeight="600"
                    android:text="" />

                <TextView
                    android:id="@+id/dry_uv_end"
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:textColor="@color/widget_subtle"
                    android:textSize="14sp"
                    android:textFontWeight="600"
                    android:text="" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Shared headline chip: the Buienalarm nowcast message (dry), a peak
         summary (rainy), or a data-state note. Full width in both states so
         it is never cropped; hidden by the worker when there is no text. -->
    <TextView
        android:id="@+id/headline"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/island_neutral"
        android:textColor="@color/widget_subtle"
        android:textSize="12sp"
        android:textFontWeight="500"
        android:maxLines="2"
        android:ellipsize="end"
        android:lineSpacingMultiplier="0.98"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:text="" />
</LinearLayout>
