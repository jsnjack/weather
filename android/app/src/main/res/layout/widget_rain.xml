<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:paddingStart="14dp"
    android:paddingEnd="10dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/condition"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="6dp"
            android:src="@drawable/ic_cond_clear"
            android:contentDescription="@string/widget_label" />

        <TextView
            android:id="@+id/location"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/widget_text"
            android:textSize="12sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end"
            android:text="@string/loading" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end"
            android:paddingStart="6dp"
            android:paddingEnd="0dp">

            <TextView
                android:id="@+id/updated"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/widget_subtle"
                android:textSize="12sp"
                android:singleLine="true"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:background="@drawable/updated_pill_background"
                android:text="" />

            <TextView
                android:id="@+id/peak"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/widget_subtle"
                android:textSize="11sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:gravity="end"
                android:maxWidth="150dp"
                android:paddingTop="2dp"
                android:text="" />
        </LinearLayout>
    </LinearLayout>

    <!-- Rainy state: the dual-provider chart bitmap. -->
    <ImageView
        android:id="@+id/chart"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scaleType="fitXY"
        android:adjustViewBounds="false"
        android:contentDescription="@string/widget_label" />

    <!-- Dry state: native Material 3 layout (crisp text, no bitmap squish). -->
    <LinearLayout
        android:id="@+id/dry_body"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:visibility="gone"
        android:paddingTop="2dp">

        <!-- Headline: the Buienalarm nowcast message, full width so it isn't
             cropped. Small and muted so the temperature stays the focus. -->
        <TextView
            android:id="@+id/dry_headline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/widget_subtle"
            android:textSize="12.5sp"
            android:textFontWeight="500"
            android:maxLines="2"
            android:ellipsize="end"
            android:lineSpacingMultiplier="0.96"
            android:paddingStart="2dp"
            android:paddingEnd="6dp"
            android:paddingBottom="4dp"
            android:text="" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

        <!-- Left: hero NOW temperature + small warm +2H, centered. -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.05"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="2dp"
            android:paddingEnd="10dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/dry_condition"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="10dp"
                    android:src="@drawable/ic_cond_clear"
                    android:contentDescription="@string/widget_label" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/widget_subtle"
                        android:textSize="10sp"
                        android:textFontWeight="700"
                        android:letterSpacing="0.16"
                        android:text="@string/now_label" />

                    <TextView
                        android:id="@+id/dry_temp_now"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/widget_text"
                        android:textSize="66sp"
                        android:textFontWeight="300"
                        android:includeFontPadding="false"
                        android:text="" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/widget_subtle"
                    android:textSize="10sp"
                    android:textFontWeight="700"
                    android:letterSpacing="0.16"
                    android:layout_marginEnd="6dp"
                    android:text="@string/plus2h_label" />

                <TextView
                    android:id="@+id/dry_temp_end"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/chart_temp"
                    android:textSize="18sp"
                    android:textFontWeight="600"
                    android:text="" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/dry_sunset_row"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="9dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/widget_subtle"
                    android:textSize="10sp"
                    android:textFontWeight="700"
                    android:letterSpacing="0.16"
                    android:layout_marginEnd="6dp"
                    android:text="@string/sunset_label" />

                <TextView
                    android:id="@+id/dry_sunset_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/widget_text"
                    android:textSize="14sp"
                    android:textFontWeight="600"
                    android:text="" />
            </LinearLayout>
        </LinearLayout>

        <!-- Right: rounded tonal stats panel with NOW / +2H columns. -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:background="@drawable/dry_panel_background"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="7dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="" />

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:textColor="@color/widget_subtle"
                    android:textSize="9sp"
                    android:textFontWeight="700"
                    android:letterSpacing="0.1"
                    android:text="@string/now_label" />

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:textColor="@color/widget_subtle"
                    android:textSize="9sp"
                    android:textFontWeight="700"
                    android:letterSpacing="0.1"
                    android:text="@string/plus2h_label" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="5dp"
                android:paddingBottom="5dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/widget_subtle"
                    android:textSize="12sp"
                    android:textFontWeight="600"
                    android:text="@string/stat_feels" />

                <TextView
                    android:id="@+id/dry_feels_now"
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:textColor="@color/widget_text"
                    android:textSize="14sp"
                    android:textFontWeight="600"
                    android:text="" />

                <TextView
                    android:id="@+id/dry_feels_end"
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:textColor="@color/widget_subtle"
                    android:textSize="14sp"
                    android:textFontWeight="600"
                    android:text="" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="5dp"
                android:paddingBottom="5dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/widget_subtle"
                    android:textSize="12sp"
                    android:textFontWeight="600"
                    android:text="@string/stat_wind" />

                <TextView
                    android:id="@+id/dry_wind_now"
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:textColor="@color/widget_text"
                    android:textSize="14sp"
                    android:textFontWeight="600"
                    android:text="" />

                <TextView
                    android:id="@+id/dry_wind_end"
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:textColor="@color/widget_subtle"
                    android:textSize="14sp"
                    android:textFontWeight="600"
                    android:text="" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="5dp"
                android:paddingBottom="5dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/widget_subtle"
                    android:textSize="12sp"
                    android:textFontWeight="600"
                    android:text="@string/stat_uv" />

                <TextView
                    android:id="@+id/dry_uv_now"
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:textColor="@color/widget_text"
                    android:textSize="14sp"
                    android:textFontWeight="600"
                    android:text="" />

                <TextView
                    android:id="@+id/dry_uv_end"
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:textColor="@color/widget_subtle"
                    android:textSize="14sp"
                    android:textFontWeight="600"
                    android:text="" />
            </LinearLayout>
        </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
