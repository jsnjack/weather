<?xml version="1.0" encoding="utf-8"?>
<!--
  Subtle rounded pill behind the "↻ Updated HH:MM" text so the tap target
  reads as a button without becoming the visual focus.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#0C202421" />
    <corners android:radius="8dp" />
</shape>
