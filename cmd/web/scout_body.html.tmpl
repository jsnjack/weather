  {{if .IsHeatmap}}
    {{if .HeatmapDaysSVG}}
    <section class="heatmaps">
      {{range .HeatmapDaysSVG}}
      <div class="heatmap-day">{{.}}</div>
      {{end}}
    </section>
    {{else}}
    <p class="empty">No heatmap data.</p>
    {{end}}
  {{else}}
    {{if .Trips}}
      {{if .RecommendationText}}<p class="recommendation"><strong>Recommendation:</strong> {{.RecommendationText}}</p>{{end}}
      {{range $i, $t := .Trips}}
      <article class="trip">
        <h3>Trip {{add $i 1}} — score {{printf "%.0f" $t.Score}}</h3>
        <p class="path">{{$t.Path}} {{if $.Cfg.RoundTrip}}(ends {{printf "%.0f" $t.EndDistKm}} km from start){{else}}(ends ~{{$t.EndLabel}}, {{printf "%.0f" $t.EndDistKm}} km away){{end}}</p>
        <table>
          <thead><tr><th></th><th>Dir</th><th>~Endpoint</th><th>Max°</th><th>Wind</th></tr></thead>
          <tbody>
            {{range $d, $row := $t.Days}}
            <tr>
              <th>Day {{add $d 1}}</th>
              <td>{{$row.Dir}}</td>
              <td>~{{$row.Label}}</td>
              <td{{if $row.Cold}} class="cold"{{end}}>{{$row.Temp}}{{if $row.Cold}}*{{end}}</td>
              <td style="color:{{$row.WindColor}}">{{$row.Wind}}</td>
            </tr>
            {{end}}
          </tbody>
        </table>
      </article>
      {{end}}
    {{else}}
      <p class="empty">No viable trip found — every bearing hit rain or severe gusts on at least one day.</p>
    {{end}}
  {{end}}

  {{if .IsHeatmap}}
  <section class="legend-card">
    <h3>Legend</h3>
    <div class="legend-group">
      <h4>Temperature (cell background)</h4>
      <span class="legend-item"><span class="swatch" style="background:#9fd6a4"></span>ideal, ≥{{printf "%.0f" .Cfg.MinTempPlus5}}°C</span>
      <span class="legend-item"><span class="swatch" style="background:#6cbf78"></span>warm, {{printf "%.0f" .Cfg.MinTemp}}–{{printf "%.0f" .Cfg.MinTempPlus5}}°C</span>
      <span class="legend-item"><span class="swatch" style="background:#e0b94f"></span>cool, {{printf "%.0f" .Cfg.MinTempMinus5}}–{{printf "%.0f" .Cfg.MinTemp}}°C</span>
      <span class="legend-item"><span class="swatch" style="background:#5c5b52;color:#fff"></span>cold, below {{printf "%.0f" .Cfg.MinTempMinus5}}°C</span>
    </div>
    <div class="legend-group">
      <h4>Wind (cell symbol)</h4>
      <span class="legend-item"><span class="swatch" style="background:#6cbf78"> </span>calm ≤10 km/h</span>
      <span class="legend-item"><span class="swatch" style="background:#6cbf78">·</span>breezy 10–25</span>
      <span class="legend-item"><span class="swatch" style="background:#6cbf78">~</span>windy 25–40</span>
      <span class="legend-item"><span class="swatch" style="background:#6cbf78">≈</span>strong 40–60</span>
    </div>
    <div class="legend-group">
      <h4>Overrides</h4>
      <span class="legend-item"><span class="swatch" style="background:#3b82f6;color:#0a0a0a">·</span>daytime rain — skip this day</span>
      <span class="legend-item"><span class="swatch" style="background:#d05c49;color:#fff">✗</span>gust ≥60 km/h — skip this day</span>
      <span class="legend-item"><span class="swatch" style="background:#0e7490;color:#ecfeff">~</span>over water — not rideable</span>
      <span class="legend-item"><span class="swatch" style="background:#9fd6a4;color:#fff;border:2px solid #fff">●</span>starting point</span>
      <span class="legend-item"><span class="swatch" style="background:#46463f"></span>no data from forecast provider</span>
    </div>
  </section>
  {{else if .Trips}}
  <section class="legend-card">
    <h3>Legend</h3>
    <div class="legend-group">
      <h4>Trip rows</h4>
      <p class="sub">Each day shows the bearing (compass arrow), endpoint locality, daytime max temp, and tail/head wind.</p>
      <span class="legend-item"><span class="swatch" style="background:transparent;color:#3f9e52">T8</span>tailwind ~8 km/h (good)</span>
      <span class="legend-item"><span class="swatch" style="background:transparent;color:#c2452f">H8</span>headwind ~8 km/h (bad)</span>
      <span class="legend-item"><span class="swatch" style="background:transparent">·</span>mostly crosswind</span>
      <span class="legend-item"><span class="swatch" style="background:transparent;color:#a5792a">19°*</span>below --min-temp ({{printf "%.0f" .Cfg.MinTemp}}°C)</span>
    </div>
    <p class="sub">Any daytime rain or gust ≥60 km/h disqualifies a day, so days like that never appear in a trip.</p>
  </section>
  {{end}}

  <footer>refreshed {{.Now}}</footer>
</main>
<script>
  if ("serviceWorker" in navigator) navigator.serviceWorker.register("/sw.js").catch(function(){});
</script>
</body>
</html>
