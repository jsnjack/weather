  {{if .Description}}<p class="desc">{{.Description}}</p>{{end}}

  {{if .ChartSVG}}<section class="chart">{{.ChartSVG}}</section>{{end}}

  {{if .HasGlance}}
  <section class="glance">
    <p class="g-row">
      <span class="g-label">now</span>
      <span class="g-temp">{{.TempNow}}°</span>
      <span class="g-mi">feels {{.FeelsNow}}°</span>
      <span class="g-mi g-mi-{{.WindNow.Class}}">{{.WindNow.Arrow}} {{.WindNow.Kmh}} km/h</span>
      <span class="g-mi g-mi-{{.UVNow.Class}}">UV {{.UVNow.Value}}</span>
    </p>
    <p class="g-row">
      <span class="g-label">+2h</span>
      <span class="g-temp">{{.TempEnd}}°</span>
      <span class="g-mi">feels {{.FeelsEnd}}°</span>
      <span class="g-mi g-mi-{{.WindEnd.Class}}">{{.WindEnd.Arrow}} {{.WindEnd.Kmh}} km/h</span>
      <span class="g-mi g-mi-{{.UVEnd.Class}}">UV {{.UVEnd.Value}}</span>
    </p>
    {{if .SunEvents}}
    <p class="g-sun">
      {{range .SunEvents}}<span>{{.Glyph}} {{.Kind}} {{.Time}}</span>{{end}}
    </p>
    {{end}}
  </section>
  {{end}}

  <footer>refreshed {{.Now}}</footer>
</main>
<script>
  if ("serviceWorker" in navigator) {
    navigator.serviceWorker.register("/sw.js").catch(function (e) { console.warn("SW", e); });
  }
</script>
</body>
</html>
