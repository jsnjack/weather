  {{if .Recommendation.Best.Name}}
  <p class="recommendation">
    <strong>Best:</strong> head {{.Recommendation.Best.Name}} — {{.BestDesc}}, {{.BestWind}}.
    {{if and .Recommendation.Worst.Name (ne .Recommendation.Worst.Name .Recommendation.Best.Name)}}
    <br><strong>Avoid:</strong> {{.Recommendation.Worst.Name}} — {{.WorstDesc}}.
    {{end}}
  </p>
  {{else}}
  <p class="empty">No rideable direction — everything around is water or missing data.</p>
  {{end}}

  <section>{{.HeatmapSVG}}</section>

  <section class="evolution">
    <h2>Wind evolution</h2>
    <p class="sub">arrow points where wind pushes you · · = calm (≤10 km/h)</p>
    <table>
      <thead>
        <tr>
          <th></th>
          {{range .HourLabels}}<th>{{.}}</th>{{end}}
        </tr>
      </thead>
      <tbody>
        {{range $row := .SectorRows}}
        <tr>
          <th{{if $row.OverWater}} class="water"{{end}}>{{$row.Name}}</th>
          {{range $row.Cells}}<td{{if $row.OverWater}} class="water"{{end}}>{{.}}</td>{{end}}
          {{if $row.OverWater}}<td class="water">(water)</td>{{end}}
        </tr>
        {{end}}
      </tbody>
    </table>
  </section>

  <section class="legend">
    <h3>Legend</h3>
    <div class="legend-group">
      <h4>Rain timing (cell background)</h4>
      <span class="legend-item"><span class="swatch" style="background:#86efac"></span>dry the entire {{.WindowHours}}-hour window</span>
      <span class="legend-item"><span class="swatch" style="background:#4ade80"></span>rain in the final 1–2 h</span>
      <span class="legend-item"><span class="swatch" style="background:#facc15"></span>rain in the middle</span>
      <span class="legend-item"><span class="swatch" style="background:#ef4444;color:#fff">✗</span>raining now or within 1 h</span>
    </div>
    <div class="legend-group">
      <h4>Wind (cell symbol — arrow points where wind pushes you)</h4>
      <span class="legend-item"><span class="swatch" style="background:#4ade80">·</span>calm ≤10 km/h</span>
      <span class="legend-item"><span class="swatch" style="background:#4ade80">→·</span>breezy 10–25</span>
      <span class="legend-item"><span class="swatch" style="background:#4ade80">→~</span>windy 25–40</span>
      <span class="legend-item"><span class="swatch" style="background:#4ade80">→≈</span>strong 40–60</span>
    </div>
    <div class="legend-group">
      <h4>Overrides</h4>
      <span class="legend-item"><span class="swatch" style="background:#86efac;color:#06b6d4">→·</span>over water, dry</span>
      <span class="legend-item"><span class="swatch" style="background:#ef4444;color:#06b6d4">✗</span>over water, raining</span>
      <span class="legend-item"><span class="swatch" style="background:#86efac;color:#fff;border:2px solid #fff">●</span>your starting point</span>
      <span class="legend-item"><span class="swatch" style="background:#3f3f46"></span>no data from forecast provider</span>
    </div>
  </section>

  <footer>refreshed {{.Now}}</footer>
</main>
<script>
  if ("serviceWorker" in navigator) navigator.serviceWorker.register("/sw.js").catch(function(){});
</script>
</body>
</html>
